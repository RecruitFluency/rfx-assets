{
  "manifest_version": 3,
  "name": "RecruitFill — College Recruiting Form Autofiller",
  "version": "1.0.0",
  "description": "Save your athlete recruiting profile once, then autofill any college coach's recruiting questionnaire with one click.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "RecruitFill — autofill this recruiting form",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/schema.js", "src/matcher.js", "src/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "fill-form": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Autofill the recruiting form on this page"
    }
  }
}
